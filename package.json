{
  "name": "sovereign-shield-orchestrator",
  "version": "2.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.5",
  "scripts": {
    "dev:full": "docker compose --profile airgap --profile cloud up --build",
    "dev:backend": "cd backend && uvicorn app:app --host 0.0.0.0 --port 8000",
    "dev:frontend": "cd frontend && pnpm dev",
    "launch": "python3 scripts/launch_ready.py",
    "deploy:enterprise": "python3 scripts/deploy_enterprise.py",
    "lint": "pnpm --dir frontend lint",
    "build": "pnpm --dir frontend build",
    "check": "python3 -m compileall backend tests && pnpm lint && pnpm build",
    "smoke:e2e": ".runtime_venv/bin/python scripts/smoke_e2e.py",
    "browser:e2e": ".runtime_venv/bin/python scripts/browser_e2e.py",
    "security:due-diligence": "bash scripts/security_due_diligence.sh",
    "deployment:pack": "python3 scripts/generate_deployment_pack.py",
    "deployment:doctor": "python3 scripts/deployment_doctor.py",
    "demo:buyer": "python3 scripts/buyer_demo.py",
    "demo:narrative": "python3 scripts/demo_narrative.py",
    "demo:investor": "python3 scripts/demo_investor.py",
    "verify:buyer": "python3 scripts/verify_buyer.py",
    "submit:ready": "python3 scripts/verify_buyer.py",
    "release:certificate": "python3 scripts/production_readiness_certificate.py",
    "handoff:pdf": "python3 scripts/generate_handoff_pdf.py",
    "handoff:zip": "python3 scripts/buyer_handoff_zip.py",
    "generate:data-room": "python3 scripts/generate_data_room.py",
    "screenshots:capture": "python3 scripts/capture_dashboard_screenshots.py",
    "production:seal": "bash scripts/production_seal.sh",
    "cross:check": "pnpm --filter @sovereign-shield/sdk check && pnpm --filter @sovereign-shield/design-system check",
    "cross:doctor": "python3 scripts/cross_platform_doctor.py",
    "desktop:dev": "pnpm --filter @sovereign-shield/desktop dev",
    "desktop:build": "pnpm --filter @sovereign-shield/desktop build",
    "mobile:dev": "pnpm --filter @sovereign-shield/mobile dev",
    "mobile:check": "pnpm --filter @sovereign-shield/mobile check",
    "web:dev": "pnpm --filter @sovereign-shield/web dev",
    "web:build": "pnpm --filter @sovereign-shield/web build"
  }
}
