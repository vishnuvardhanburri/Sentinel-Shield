# Sovereign Shield Production Environment
# Copy to .env on the buyer host. Never commit the filled file.
# Default posture: buyer-owned database + local AI. No third-party LLM API key is required.

DEPLOYMENT_MODE=airgap
CLOUD_ADAPTERS_ENABLED=false

# Required database. Use buyer-owned Postgres in production.
DATABASE_URL=postgresql+psycopg2://sentinel:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/sentinel
REDIS_URL=redis://redis:6379/0

# Required fail-closed secrets. Generate with: pnpm production:seal
JWT_SECRET_KEY=CHANGE_ME_MIN_48_CHARS_RANDOM
LICENSE_MASTER_SECRET=CHANGE_ME_MIN_48_CHARS_RANDOM
ACTOR_HASH_SALT=CHANGE_ME_MIN_32_CHARS_RANDOM
LEDGER_MASTER_SALT=CHANGE_ME_MIN_32_CHARS_RANDOM

# Lock the API to the deployed dashboard origin.
ALLOWED_ORIGINS=https://sovereign-shield.xaviratechlabs.com

# Auth and onboarding.
JWT_EXPIRY_HOURS=8
JWT_REFRESH_DAYS=7
ENABLE_SELF_REGISTRATION=false
REGISTRATION_INVITE_TOKEN=
FIRST_RUN_ADMIN_EMAIL=admin@sovereign.local

# Zero-trust API shield.
API_SHIELD_ENFORCE_MTLS=true
API_SHIELD_MAX_REQUESTS=120
API_SHIELD_WINDOW_SECONDS=60
API_SHIELD_MAX_COST_USD=5.0
API_SHIELD_MAX_BODY_BYTES=524288
API_SHIELD_PROTECTED_PREFIXES=/ask,/api/v2/chat,/api/v2/proxy,/api/v2/audit,/audit,/export-audit

# Local model runtime. This is the default AI path.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1
ENABLE_MODEL_PULL=false

# Optional cloud adapters are disabled by default.
# Only add provider keys if a buyer deliberately sets CLOUD_ADAPTERS_ENABLED=true.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=

# Alerts and reports are optional buyer-owned integrations.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
REPORT_EMAIL_TO=
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
SIEM_WEBHOOK_URL=

# Tenant and update channel.
DEFAULT_TENANT_ID=default
UPDATE_CHECK=false
UPDATE_SERVER_URL=

# Cross-platform operator consoles.
SOVEREIGN_API_URL=https://gateway.sovereign-shield.example
NEXT_PUBLIC_SOVEREIGN_API_URL=https://gateway.sovereign-shield.example
TAURI_SIGNING_CHANNEL=buyer-managed
MOBILE_CERTIFICATE_PINNING=required
