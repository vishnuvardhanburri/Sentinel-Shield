# ════════════════════════════════════════════════════════════════════════════
#  Sentinel Shield v2 — Environment Configuration
#  Copy to .env and fill in your values before running.
#
#  ⚠️  NEVER commit a filled-in .env to git — it's in .gitignore
#  🔐  For production, use AWS Secrets Manager or HashiCorp Vault instead.
# ════════════════════════════════════════════════════════════════════════════

# ── Deployment Mode ──────────────────────────────────────────────────────────
# Options: airgap (local only) | cloud (API-based LLMs) | hybrid
DEPLOYMENT_MODE=airgap

# ── Security ─────────────────────────────────────────────────────────────────
# CRITICAL: Change these in production. Use: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_PRODUCTION_SEAL_MIN_48_CHARS
LICENSE_MASTER_SECRET=CHANGE_ME_GENERATE_WITH_PRODUCTION_SEAL_MIN_48_CHARS
ACTOR_HASH_SALT=CHANGE_ME_GENERATE_WITH_PRODUCTION_SEAL_MIN_32_CHARS
LEDGER_MASTER_SALT=CHANGE_ME_GENERATE_WITH_PRODUCTION_SEAL_MIN_32_CHARS

# ── License Server ────────────────────────────────────────────────────────────
# Leave blank for air-gap offline validation.
# Set to your hosted license server URL for cloud/SaaS mode.
LICENSE_SERVER_URL=

# JWT Settings
JWT_EXPIRY_HOURS=8
JWT_REFRESH_DAYS=7

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (air-gap / local): leave as default
DATABASE_URL=sqlite:///./sentinel.db

# PostgreSQL (cloud / enterprise):
# DATABASE_URL=postgresql+psycopg2://sentinel:CHANGE_ME@localhost:5432/sentinel

# Database settings
DB_USER=sentinel
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_ECHO=false   # Set true to log all SQL queries (dev only)

# ── Redis (Cloud Mode) ───────────────────────────────────────────────────────
# Required for session caching in cloud mode. Leave blank for air-gap.
REDIS_URL=

# ── AI Model Configuration ───────────────────────────────────────────────────
# Ollama (air-gap / local GPU)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# OpenAI (cloud mode)
OPENAI_API_KEY=

# Anthropic Claude (cloud mode)
ANTHROPIC_API_KEY=

# Google Gemini (cloud mode)
GEMINI_API_KEY=

# ── Vector Store ──────────────────────────────────────────────────────────────
# Leave blank = local Chroma (air-gap default)
# Set for cloud: pinecone | weaviate | qdrant
VECTOR_STORE=chroma
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=

# ── Email / Alerts ────────────────────────────────────────────────────────────
# SMTP for monthly security reports and breach alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@yourdomain.com
SMTP_PASS=your_app_password_here

# Alert recipient (usually the compliance officer or CISO)
REPORT_EMAIL_TO=compliance@your-organization.com
REPORT_CYCLE_DAYS=30

# ── Webhooks ──────────────────────────────────────────────────────────────────
# Real-time critical breach alerts
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# ── System Behavior ───────────────────────────────────────────────────────────
NOTIFY_SOUND=yes        # Desktop notification sound (yes/no)
UPDATE_CHECK=true       # Check for updates from VishnuLabs
UPDATE_SERVER_URL=https://api.vishnulabs.com/sentinel/version

# ── Observability (Production) ────────────────────────────────────────────────
# Sentry error tracking
SENTRY_DSN=

# Prometheus metrics endpoint (set to /metrics to enable)
METRICS_PATH=

# ── Multi-Tenancy (Enterprise Cloud) ─────────────────────────────────────────
# Default tenant ID for single-tenant installations
DEFAULT_TENANT_ID=default

# ── CORS ─────────────────────────────────────────────────────────────────────
# In production, restrict to your frontend domain
ALLOWED_ORIGINS=http://localhost:3000

# ── Secrets Manager Integration ──────────────────────────────────────────────
# AWS Secrets Manager (Enterprise / Cloud deployments)
# When set, all *_KEY and *_PASSWORD values above are IGNORED in favour of
# values fetched from AWS at runtime.
# AWS_SECRETS_MANAGER_ARN=arn:aws:secretsmanager:ap-south-1:123456789:secret:sentinel-prod
# AWS_REGION=ap-south-1
