# Sovereign Shield v2 — Local Environment Configuration
# Copy to .env and fill in values before running.
# Never commit a filled .env file.

# Default posture: database + local AI. No third-party LLM key is required.
DEPLOYMENT_MODE=airgap
CLOUD_ADAPTERS_ENABLED=false

# Required fail-closed secrets. Use: pnpm production:seal
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_PRODUCTION_SEAL_MIN_48_CHARS
LICENSE_MASTER_SECRET=CHANGE_ME_GENERATE_WITH_PRODUCTION_SEAL_MIN_48_CHARS
ACTOR_HASH_SALT=CHANGE_ME_GENERATE_WITH_PRODUCTION_SEAL_MIN_32_CHARS
LEDGER_MASTER_SALT=CHANGE_ME_GENERATE_WITH_PRODUCTION_SEAL_MIN_32_CHARS

# Database: SQLite for local demo, buyer-owned Postgres for production.
DATABASE_URL=sqlite:///./sentinel.db
# DATABASE_URL=postgresql+psycopg2://sentinel:CHANGE_ME@localhost:5432/sentinel

# Redis is optional for local demo and recommended for production.
REDIS_URL=

# Local model runtime.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# CORS.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Auth.
JWT_EXPIRY_HOURS=8
JWT_REFRESH_DAYS=7
ENABLE_SELF_REGISTRATION=false
FIRST_RUN_ADMIN_EMAIL=admin@sovereign.local

# Zero-trust API shield.
API_SHIELD_ENFORCE_MTLS=false
API_SHIELD_MAX_REQUESTS=120
API_SHIELD_WINDOW_SECONDS=60
API_SHIELD_MAX_COST_USD=5.0
API_SHIELD_MAX_BODY_BYTES=524288

# Optional buyer-owned alerts/reports.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
REPORT_EMAIL_TO=
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
SIEM_WEBHOOK_URL=

# Optional cloud adapters are disabled by default.
# Only add provider keys if a buyer deliberately sets CLOUD_ADAPTERS_ENABLED=true.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=

DEFAULT_TENANT_ID=default
UPDATE_CHECK=false
UPDATE_SERVER_URL=

# Cross-platform operator consoles.
SOVEREIGN_API_URL=http://localhost:8000
NEXT_PUBLIC_SOVEREIGN_API_URL=http://localhost:8000
MOBILE_CERTIFICATE_PINNING=required_for_production
