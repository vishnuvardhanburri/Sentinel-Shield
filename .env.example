# SENTINEL SHIELD - Production Configuration
# ------------------------------------------

# --- 1. REPORTING / ALERT EMAIL (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
REPORT_EMAIL_TO=

# --- 2. REAL-TIME WEBHOOKS / NOTIFICATIONS ---
DISCORD_WEBHOOK_URL=
# Enable sound for desktop notifications (yes/no)
NOTIFY_SOUND=yes

# --- 3. SYSTEM FREQUENCY ---
# Production standard is 30 days. Mock for testing is 1.
REPORT_CYCLE_DAYS=30

# --- 4. LIFETIME UPDATES ---
# Set to 'false' for 100% air-gapped mode.
UPDATE_CHECK=true
UPDATE_SERVER_URL=https://api.vishnulabs.com/sentinel/version
