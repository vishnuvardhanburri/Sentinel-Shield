{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sovereign Shield",
  "version": "0.1.0",
  "identifier": "labs.xavira.sovereignshield",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build:web",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https:; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    },
    "windows": [
      {
        "title": "Sovereign Shield",
        "width": 1280,
        "height": 820,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi", "appimage"],
    "publisher": "Xavira Tech Labs",
    "copyright": "Xavira Tech Labs 2026"
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": ["https://updates.xavira.example/sovereign-shield/{{target}}/{{current_version}}"],
      "pubkey": "BUYER_REPLACES_WITH_TAURI_UPDATE_PUBLIC_KEY"
    }
  }
}
