{
  "manifest_version": 3,
  "name": "Sentinel Shield — Enterprise AI Governance",
  "version": "1.0.0",
  "description": "Enterprise-grade PII/PHI redaction for ChatGPT, Claude, and Gemini.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "http://localhost:8000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/sentinel-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/sentinel-128.png",
    "48": "icons/sentinel-128.png",
    "128": "icons/sentinel-128.png"
  }
}
